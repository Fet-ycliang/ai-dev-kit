# Databricks Builder App - 環境設定
# ==================================================
#
# 用於本機開發：setup script 會自動將此檔案複製為 `.env.local`。
#   若您是手動設定，請將此檔案複製為 `.env.local`，並填入您的值。
# 用於部署：請將 `app.yaml.example` 複製為 `app.yaml`，並在該檔中完成設定。
#
# 此 app 在本機開發時會載入 `.env.local`。部署到 Databricks Apps 時，
# 請改用 `app.yaml` 作為環境設定檔。

# =============================================================================
# Databricks 設定（本機開發）
# =============================================================================
# Workspace URL 與個人存取權杖
# 在正式環境（Databricks Apps）中，驗證會透過
# 服務主體的 OAuth 憑證自動處理，不需要 token。
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...

# =============================================================================
# 資料庫設定（Lakebase）
# =============================================================================
# 請從下列選項中擇一使用。app 會依據
# 已設定的變數自動判斷模式（`LAKEBASE_ENDPOINT` 的優先順序高於 `LAKEBASE_INSTANCE_NAME`）。

# 選項 1a：Autoscale Lakebase — 建議使用（閒置時可縮放至零）
# 可於此路徑找到 endpoint 名稱：Catalog → Lakebase → 您的專案 → Branches → Endpoints
# 格式：projects/<project-name>/branches/<branch>/endpoints/<endpoint>
LAKEBASE_ENDPOINT=projects/your-project/branches/production/endpoints/primary
LAKEBASE_DATABASE_NAME=databricks_postgres

# 選項 1b：Provisioned Lakebase — 固定容量
# 可於此路徑找到 instance 名稱：Catalog → Lakebase → 您的 instance
# LAKEBASE_INSTANCE_NAME=your-lakebase-instance
# LAKEBASE_DATABASE_NAME=databricks_postgres

# 選項 2：固定連線 URL — 最適合本機開發的簡單方式（不會自動更新 token）
# 格式：postgresql://<email-urlencoded>:<oauth-token>@<host>:5432/<database>?sslmode=require
# 範例（autoscale host）：
# LAKEBASE_PG_URL=postgresql://anirvan.sen%40databricks.com:dapi...@ep-dry-sound-d2p70ooh.database.us-east-1.cloud.databricks.com:5432/databricks_postgres?sslmode=require
# 範例（provisioned host）：
# LAKEBASE_PG_URL=postgresql://anirvan.sen%40databricks.com:dapi...@my-instance.database.cloud.databricks.com:5432/databricks_postgres?sslmode=require
# 注意：email 中的 `@` 必須 URL encode 為 `%40`。Token 約在 1 小時後過期。

# =============================================================================
# LLM 提供者設定
# =============================================================================
# 選擇您的 LLM 提供者：`DATABRICKS`（預設）或 `AZURE`
LLM_PROVIDER=DATABRICKS

# Databricks Foundation Models（請依您的 workspace 中可用模型調整）
# 範例：databricks-meta-llama-3-3-70b-instruct、databricks-claude-sonnet-4
DATABRICKS_MODEL=databricks-meta-llama-3-3-70b-instruct
DATABRICKS_MODEL_MINI=databricks-gemini-3-flash

# Azure OpenAI（若改用 Azure，請取消註解）
# LLM_PROVIDER=AZURE
# AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# =============================================================================
# Skills 設定
# =============================================================================
# 要包含的 Skills（以逗號分隔的 skill 資料夾名稱清單）
ENABLED_SKILLS=databricks-agent-bricks,databricks-python-sdk,databricks-spark-declarative-pipelines,databricks-synthetic-data-gen,databricks-unstructured-pdf-generation

# 選用：加入額外的 Skills（以下為使用 `databricks-` 前綴 skills 的範例）
# ENABLED_SKILLS=databricks-agent-bricks,databricks-python-sdk,databricks-spark-declarative-pipelines,databricks-synthetic-data-gen,databricks-unstructured-pdf-generation

# 測試模式：僅啟用 Skill 工具（有助於除錯）
SKILLS_ONLY_MODE=false

# =============================================================================
# 應用程式設定
# =============================================================================
# Projects 目錄（Claude Code agent 會在此處工作）
PROJECTS_BASE_DIR=./projects

# 環境（development 或 production）
ENV=development

# Claude SDK 串流逾時時間，單位為毫秒（預設：1 小時）
# 若您有執行時間很長的操作，可提高此值
CLAUDE_CODE_STREAM_CLOSE_TIMEOUT=3600000

# Anthropic API key（選用，預設使用 Databricks model serving）
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# MLflow Tracing 設定
# =============================================================================
# 為 Claude Code 對話啟用 MLflow tracing
# 參考：https://docs.databricks.com/aws/en/mlflow3/genai/tracing/integrations/claude-code
MLFLOW_TRACKING_URI=databricks
# 選用：為 traces 指定自訂 experiment
# MLFLOW_EXPERIMENT_NAME=/Users/your-email@company.com/claude-code-traces

# =============================================================================
# 部署到 DATABRICKS APPS
# =============================================================================
#
# 若要將此 app 部署到 Databricks Apps：
#
# 1. 先決條件：
#    - 已安裝並完成 Databricks CLI 設定（`databricks auth login`）
#    - 已在 workspace 中建立 Lakebase instance（autoscale 或 provisioned）
#
# 2. 建立 app：
#    databricks apps create <your-app-name>
#
# 3. 設定 `app.yaml`：
#    cp app.yaml.example app.yaml
#    # 編輯 app.yaml — 設定 LAKEBASE_ENDPOINT（autoscale）或
#    # LAKEBASE_INSTANCE_NAME（provisioned），以及您的 LLM 模型設定
#
# 4. 將 Lakebase 加入為 app 資源（僅 provisioned 需要；autoscale 會直接使用 OAuth）：
#    databricks apps add-resource <your-app-name> \
#      --resource-type database \
#      --resource-name lakebase \
#      --database-instance <your-lakebase-instance-name>
#
# 5. 將資料表權限授予 app 的服務主體：
#    （首次部署後，請在 notebook 或 SQL editor 中執行以下 SQL）
#    
#    GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public 
#      TO `<service-principal-id>`;
#    GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public 
#      TO `<service-principal-id>`;
#    ALTER DEFAULT PRIVILEGES IN SCHEMA public 
#      GRANT ALL ON TABLES TO `<service-principal-id>`;
#
# 6. 部署：
#    ./scripts/deploy.sh <your-app-name>
#
# 更多細節請參閱 `README.md`
